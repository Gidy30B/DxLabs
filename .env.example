# Destination inbox for website enquiries.
CONTACT_TO_EMAIL=dxlabssupport@gmail.com

# Must be a sender or domain accepted by Resend.
# Configure separate values for Production, Preview and Development if needed.
CONTACT_FROM_EMAIL=DxLabs Website <enquiries@your-verified-domain.example>
